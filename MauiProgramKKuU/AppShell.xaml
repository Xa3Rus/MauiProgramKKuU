<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="MauiProgramKKuU.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:MauiProgramKKuU.Pages"
    Title="MauiProgramKKuU">

    <FlyoutItem Title="Главная">
        <ShellContent
            Title="Главная"
            ContentTemplate="{DataTemplate pages:HomePage}"
            Route="HomePage" />
    </FlyoutItem>

    <FlyoutItem Title="История">
        <ShellContent
            Title="История"
            ContentTemplate="{DataTemplate pages:HistoryPage}"
            Route="HistoryPage" />
    </FlyoutItem>

    <FlyoutItem Title="Сравнение">
        <ShellContent
            Title="Сравнение"
            ContentTemplate="{DataTemplate pages:ComparePage}"
            Route="ComparePage" />
    </FlyoutItem>

    <FlyoutItem Title="Настройки">
        <ShellContent
            Title="Настройки"
            ContentTemplate="{DataTemplate pages:SettingsPage}"
            Route="SettingsPage" />
    </FlyoutItem>

    <FlyoutItem Title="FAQ">
        <ShellContent
            Title="FAQ"
            ContentTemplate="{DataTemplate pages:FaqPage}"
            Route="FaqPage" />
    </FlyoutItem>

</Shell>
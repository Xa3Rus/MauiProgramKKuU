<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiProgramKKuU.Pages.MortgagePage"
             BackgroundColor="{DynamicResource AppBackgroundColor}">

    <Grid>
        <!-- Фон -->
        <Image Source="bg.png" Aspect="AspectFill" Opacity="0.2" />
        <BoxView Color="{DynamicResource AppBackgroundColor}" Opacity="0.72" />

        <ScrollView>
            <VerticalStackLayout Padding="30" Spacing="20">

                <Label x:Name="PageTitleLabel"
                       Text="Калькулятор ипотеки"
                       FontSize="30"
                       FontAttributes="Bold"
                       TextColor="{DynamicResource AppTextColor}"
                       HorizontalOptions="Center"
                       Margin="0,20,0,10"/>

                <Border BackgroundColor="{DynamicResource CardBackgroundColor}"
                        Stroke="{DynamicResource AccentColor}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 24"
                        Padding="20">

                    <VerticalStackLayout Spacing="16">

                        <Label x:Name="PropertyPriceLabel"
                               Text="Стоимость недвижимости"
                               TextColor="{DynamicResource AppTextColor}"
                               FontSize="18"/>

                        <Entry x:Name="PropertyPriceEntry"
                               Placeholder="Например 5000000"
                               TextColor="{DynamicResource AppTextColor}"
                               PlaceholderColor="{DynamicResource AppSubtextColor}"
                               Keyboard="Numeric"
                               BackgroundColor="{DynamicResource InputBackgroundColor}" />

                        <Label x:Name="InitialPaymentLabel"
                               Text="Первоначальный взнос"
                               TextColor="{DynamicResource AppTextColor}"
                               FontSize="18"/>

                        <Entry x:Name="InitialPaymentEntry"
                               Placeholder="Например 1000000"
                               TextColor="{DynamicResource AppTextColor}"
                               PlaceholderColor="{DynamicResource AppSubtextColor}"
                               Keyboard="Numeric"
                               BackgroundColor="{DynamicResource InputBackgroundColor}" />

                        <Label x:Name="RateLabel"
                               Text="Процентная ставка (%)"
                               TextColor="{DynamicResource AppTextColor}"
                               FontSize="18"/>

                        <Entry x:Name="RateEntry"
                               Placeholder="Например 10.5"
                               TextColor="{DynamicResource AppTextColor}"
                               PlaceholderColor="{DynamicResource AppSubtextColor}"
                               Keyboard="Numeric"
                               BackgroundColor="{DynamicResource InputBackgroundColor}" />

                        <Label x:Name="MonthsLabel"
                               Text="Срок (месяцы)"
                               TextColor="{DynamicResource AppTextColor}"
                               FontSize="18"/>

                        <Entry x:Name="MonthsEntry"
                               Placeholder="Например 240"
                               TextColor="{DynamicResource AppTextColor}"
                               PlaceholderColor="{DynamicResource AppSubtextColor}"
                               Keyboard="Numeric"
                               BackgroundColor="{DynamicResource InputBackgroundColor}" />

                        <Label x:Name="PaymentTypeLabel"
                               Text="Тип платежа"
                               TextColor="{DynamicResource AppTextColor}"
                               FontSize="18"/>

                        <Picker x:Name="PaymentTypePicker"
                                Title="Выберите тип платежа"
                                TextColor="{DynamicResource AppTextColor}"
                                BackgroundColor="{DynamicResource InputBackgroundColor}">
                            <Picker.Items>
                                <x:String>Аннуитетный</x:String>
                                <x:String>Дифференцированный</x:String>
                            </Picker.Items>
                        </Picker>

                        <Label x:Name="PresetLabel"
                               Text="Быстрые пресеты"
                               TextColor="{DynamicResource AppTextColor}"
                               FontSize="18"/>
                        <Picker x:Name="PresetPicker"
                                SelectedIndexChanged="OnPresetChanged"
                                Title="Выберите пресет"
                                TextColor="{DynamicResource AppTextColor}"
                                BackgroundColor="{DynamicResource InputBackgroundColor}">
                            <Picker.Items>
                                <x:String>Пусто</x:String>
                                <x:String>Эконом</x:String>
                                <x:String>Семейная</x:String>
                                <x:String>Бизнес</x:String>
                            </Picker.Items>
                        </Picker>

                        <Button x:Name="CalculateButton"
                                Text="Рассчитать"
                                Clicked="OnCalculateClicked"
                                HeightRequest="60"
                                FontSize="22"
                                FontAttributes="Bold"
                                TextColor="{DynamicResource AppTextColor}"
                                CornerRadius="20"
                                BackgroundColor="{DynamicResource PrimaryButtonColor}" />
                    </VerticalStackLayout>
                </Border>

                <Border BackgroundColor="{DynamicResource AltCardBackgroundColor}"
                        Stroke="{DynamicResource AccentColor}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 24"
                        Padding="20">

                    <VerticalStackLayout Spacing="12">
                        <Label x:Name="ResultHeaderLabel"
                               Text="Результат"
                               TextColor="{DynamicResource AppTextColor}"
                               FontSize="22"
                               FontAttributes="Bold"/>

                        <Label x:Name="LoanAmountLabel"
                               Text="Сумма ипотеки: -"
                               TextColor="{DynamicResource AppSubtextColor}"
                               FontSize="18"/>

                        <Label x:Name="MonthlyPaymentLabel"
                               Text="Ежемесячный платеж: -"
                               TextColor="{DynamicResource AppSubtextColor}"
                               FontSize="18"/>

                        <Label x:Name="TotalPaymentLabel"
                               Text="Общая выплата: -"
                               TextColor="{DynamicResource AppSubtextColor}"
                               FontSize="18"/>

                        <Label x:Name="OverpaymentLabel"
                               Text="Переплата: -"
                               TextColor="{DynamicResource AppSubtextColor}"
                               FontSize="18"/>

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
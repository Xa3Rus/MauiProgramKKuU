<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiProgramKKuU.Pages.ComparePage">
    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="10">
            <Label x:Name="CompareTitleLabel" Text="Сравнение 3 сценариев" FontSize="24" FontAttributes="Bold" />
            <Entry x:Name="AmountEntry" Placeholder="Сумма" Keyboard="Numeric" />
            <Entry x:Name="RateEntry" Placeholder="Ставка %" Keyboard="Numeric" />
            <Entry x:Name="MonthsEntry" Placeholder="Базовый срок (мес.)" Keyboard="Numeric" />
            <Button x:Name="CompareButton" Text="Сравнить" Clicked="OnCompareClicked" />

            <Label x:Name="Scenario1Label" />
            <Label x:Name="Scenario2Label" />
            <Label x:Name="Scenario3Label" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>

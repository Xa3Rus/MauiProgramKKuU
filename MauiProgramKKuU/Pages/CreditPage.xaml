<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiProgramKKuU.Pages.CreditPage"
             BackgroundColor="{DynamicResource AppBackgroundColor}">

    <Grid>
        <!-- Фон -->
        <Image Source="bg.png" Aspect="AspectFill" Opacity="0.2" />
        <BoxView Color="{DynamicResource AppBackgroundColor}" Opacity="0.72" />

        <ScrollView>
            <VerticalStackLayout Padding="30" Spacing="20">

                <Label x:Name="PageTitleLabel"
                       Text="Калькулятор кредита"
                       FontSize="30"
                       FontAttributes="Bold"
                       TextColor="{DynamicResource AppTextColor}"
                       HorizontalOptions="Center"
                       Margin="0,20,0,10"/>

                <Border BackgroundColor="{DynamicResource CardBackgroundColor}"
                        Stroke="{DynamicResource AccentColor}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 24"
                        Padding="20">

                    <VerticalStackLayout Spacing="16">

                        <Label x:Name="AmountLabel"
                               Text="Сумма кредита"
                               TextColor="{DynamicResource AppTextColor}"
                               FontSize="18"/>

                        <Entry x:Name="AmountEntry"
                               Placeholder="Например 1000000"
                               TextColor="{DynamicResource AppTextColor}"
                               PlaceholderColor="{DynamicResource AppSubtextColor}"
                               Keyboard="Numeric"
                               BackgroundColor="{DynamicResource InputBackgroundColor}"
                               TextChanged="OnInputTextChanged" />

                        <Label x:Name="RateLabel"
                               Text="Процентная ставка (%)"
                               TextColor="{DynamicResource AppTextColor}"
                               FontSize="18"/>

                        <Entry x:Name="RateEntry"
                               Placeholder="Например 12.5"
                               TextColor="{DynamicResource AppTextColor}"
                               PlaceholderColor="{DynamicResource AppSubtextColor}"
                               Keyboard="Numeric"
                               BackgroundColor="{DynamicResource InputBackgroundColor}"
                               TextChanged="OnInputTextChanged" />

                        <Label x:Name="MonthsLabel"
                               Text="Срок (месяцы)"
                               TextColor="{DynamicResource AppTextColor}"
                               FontSize="18"/>

                        <Entry x:Name="MonthsEntry"
                               Placeholder="Например 60"
                               TextColor="{DynamicResource AppTextColor}"
                               PlaceholderColor="{DynamicResource AppSubtextColor}"
                               Keyboard="Numeric"
                               BackgroundColor="{DynamicResource InputBackgroundColor}"
                               TextChanged="OnInputTextChanged" />

                        <Label x:Name="PaymentTypeLabel"
                               Text="Тип платежа"
                               TextColor="{DynamicResource AppTextColor}"
                               FontSize="18"/>

                        <Picker x:Name="PaymentTypePicker"
                                Title="Выберите тип платежа"
                                TextColor="{DynamicResource AppTextColor}"
                                BackgroundColor="{DynamicResource InputBackgroundColor}"
                                SelectedIndexChanged="OnInputSelectionChanged">
                            <Picker.Items>
                                <x:String>Аннуитетный</x:String>
                                <x:String>Дифференцированный</x:String>
                            </Picker.Items>
                        </Picker>

                        <Label x:Name="PresetLabel"
                               Text="Быстрые пресеты"
                               TextColor="{DynamicResource AppTextColor}"
                               FontSize="18"/>
                        <Picker x:Name="PresetPicker"
                                SelectedIndexChanged="OnPresetChanged"
                                Title="Выберите пресет"
                                TextColor="{DynamicResource AppTextColor}"
                                BackgroundColor="{DynamicResource InputBackgroundColor}">
                            <Picker.Items>
                                <x:String>Пусто</x:String>
                                <x:String>Потребительский</x:String>
                                <x:String>Авто</x:String>
                                <x:String>Ипотечный стандарт</x:String>
                            </Picker.Items>
                        </Picker>

                        <!-- No explicit "Calculate" button: results are recalculated live while typing. -->
                    </VerticalStackLayout>
                </Border>

                <Border BackgroundColor="{DynamicResource AltCardBackgroundColor}"
                        Stroke="{DynamicResource AccentColor}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 24"
                        Padding="20">

                    <VerticalStackLayout Spacing="12">
                        <Label x:Name="ResultHeaderLabel"
                               Text="Результат"
                               TextColor="{DynamicResource AppTextColor}"
                               FontSize="22"
                               FontAttributes="Bold"/>

                        <!-- Segmented bar: сумма кредита vs переплата -->
                        <HorizontalStackLayout x:Name="SplitBarLegend"
                                                 Spacing="16"
                                                 IsVisible="False">
                            <HorizontalStackLayout Spacing="8">
                                <BoxView WidthRequest="10"
                                         HeightRequest="10"
                                         CornerRadius="5"
                                         Color="{DynamicResource AccentColor}" />
                                <Label x:Name="SplitLeftLegendLabel"
                                       Text=""
                                       FontSize="14"
                                       TextColor="{DynamicResource AppSubtextColor}" />
                            </HorizontalStackLayout>
                            <HorizontalStackLayout Spacing="8">
                                <BoxView WidthRequest="10"
                                         HeightRequest="10"
                                         CornerRadius="5"
                                         Color="#F59E0B" />
                                <Label x:Name="SplitRightLegendLabel"
                                       Text=""
                                       FontSize="14"
                                       TextColor="#F59E0B" />
                            </HorizontalStackLayout>
                        </HorizontalStackLayout>

                        <Border x:Name="SplitBarBorder"
                                BackgroundColor="{DynamicResource InputBackgroundColor}"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 16"
                                Padding="0"
                                HeightRequest="18"
                                IsVisible="False">
                            <Grid x:Name="SplitBarGrid"
                                  ColumnDefinitions="Auto,Auto"
                                  HeightRequest="18"
                                  ColumnSpacing="2"
                                  HorizontalOptions="FillAndExpand">
                                <BoxView x:Name="SplitBarAmountFill"
                                         Grid.Column="0"
                                         BackgroundColor="{DynamicResource AccentColor}"
                                         HeightRequest="18" />
                                <BoxView x:Name="SplitBarOverpaymentFill"
                                         Grid.Column="1"
                                         BackgroundColor="#F59E0B"
                                         HeightRequest="18" />
                            </Grid>
                        </Border>

                        <Label x:Name="MonthlyPaymentLabel"
                               Text="Ежемесячный платеж: -"
                               TextColor="{DynamicResource AppSubtextColor}"
                               FontSize="18"/>

                        <Label x:Name="TotalPaymentLabel"
                               Text="Общая выплата: -"
                               TextColor="{DynamicResource AppSubtextColor}"
                               FontSize="18"/>

                        <Label x:Name="OverpaymentLabel"
                               Text="Переплата: -"
                               TextColor="{DynamicResource AppSubtextColor}"
                               FontSize="18"/>

                        <Button x:Name="OpenAnalyticsButton"
                                Text="Аналитика"
                                Clicked="OnOpenAnalyticsClicked"
                                HeightRequest="56"
                                FontSize="18"
                                FontAttributes="Bold"
                                TextColor="{DynamicResource AppTextColor}"
                                CornerRadius="18"
                                BackgroundColor="{DynamicResource PrimaryButtonColor}" />

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
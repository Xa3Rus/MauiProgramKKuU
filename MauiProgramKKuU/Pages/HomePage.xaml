<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiProgramKKuU.Pages.HomePage"
             BackgroundColor="#0D1028">
    <Grid>
        <Image Source="bg.png" Aspect="AspectFill" Opacity="0.35" />
        <BoxView Color="#0D1028" Opacity="0.75" />

        <ScrollView>
            <VerticalStackLayout Padding="20,28" Spacing="18">
                <Border StrokeShape="RoundRectangle 26"
                        BackgroundColor="#332D3D80"
                        Stroke="#5A8CFF"
                        StrokeThickness="1"
                        Padding="20">
                    <VerticalStackLayout Spacing="8">
                        <Label x:Name="MainTitleLabel"
                               Text="Калькулятор кредитов"
                               TextColor="White"
                               FontAttributes="Bold"
                               FontSize="32" />
                        <Label x:Name="SubtitleLabel"
                               Text="Быстрый расчет кредита и ипотеки"
                               TextColor="#D8DEFF"
                               FontSize="16" />
                    </VerticalStackLayout>
                </Border>

                <Grid x:Name="CreditCard"
                      ColumnDefinitions="Auto,*"
                      ColumnSpacing="14"
                      Padding="18"
                      BackgroundColor="#334658A6"
                      MinimumHeightRequest="98">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnCreditTapped" />
                    </Grid.GestureRecognizers>

                    <Image Source="credit.png"
                           WidthRequest="34"
                           HeightRequest="34"
                           VerticalOptions="Center" />
                    <Label Grid.Column="1"
                           x:Name="CreditCardTitle"
                           Text="Кредиты"
                           TextColor="White"
                           FontAttributes="Bold"
                           FontSize="24"
                           LineBreakMode="WordWrap"
                           VerticalOptions="Center" />
                </Grid>

                <Grid x:Name="MortgageCard"
                      ColumnDefinitions="Auto,*"
                      ColumnSpacing="14"
                      Padding="18"
                      BackgroundColor="#333E4A96"
                      MinimumHeightRequest="98">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnMortgageTapped" />
                    </Grid.GestureRecognizers>

                    <Image Source="mortgage.png"
                           WidthRequest="34"
                           HeightRequest="34"
                           VerticalOptions="Center" />
                    <Label Grid.Column="1"
                           x:Name="MortgageCardTitle"
                           Text="Ипотека"
                           TextColor="White"
                           FontAttributes="Bold"
                           FontSize="24"
                           LineBreakMode="WordWrap"
                           VerticalOptions="Center" />
                </Grid>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
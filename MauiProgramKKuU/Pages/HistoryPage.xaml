<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiProgramKKuU.Pages.HistoryPage">
    <Grid Padding="16" RowDefinitions="Auto,Auto,*" BackgroundColor="{DynamicResource AppBackgroundColor}">
        <Label x:Name="HistoryTitleLabel"
               Text="Последние расчеты"
               FontSize="24"
               FontAttributes="Bold" />

        <Button x:Name="ClearButton"
                Grid.Row="1"
                Text="Очистить историю"
                Clicked="OnClearClicked"
                Margin="0,12,0,12" />

        <CollectionView Grid.Row="2"
                        x:Name="HistoryCollectionView">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border StrokeThickness="1"
                            Stroke="{DynamicResource AccentColor}"
                            BackgroundColor="{DynamicResource CardBackgroundColor}"
                            StrokeShape="RoundRectangle 16"
                            Padding="12"
                            Margin="0,0,0,10">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding ProductType}" FontAttributes="Bold" />
                            <Label Text="{Binding PaymentType}" />
                            <Label Text="{Binding CreatedAtLocalText}" FontSize="12" />
                            <Label Text="{Binding MainLine}" />
                            <Label Text="{Binding TotalLine}" />
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>

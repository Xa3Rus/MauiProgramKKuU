<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:MauiProgramKKuU"
             x:Class="MauiProgramKKuU.App">
    <Application.Resources>
        <ResourceDictionary>
            <Color x:Key="AppBackgroundColor">#0D1028</Color>
            <Color x:Key="CardBackgroundColor">#1A2342</Color>
            <Color x:Key="AltCardBackgroundColor">#24345E</Color>
            <Color x:Key="AccentColor">#4F46E5</Color>
            <Color x:Key="AppTextColor">#F1F5F9</Color>
            <Color x:Key="AppSubtextColor">#B8C3D9</Color>
            <Color x:Key="InputBackgroundColor">#2A365F</Color>
            <Color x:Key="PrimaryButtonColor">#4338CA</Color>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
